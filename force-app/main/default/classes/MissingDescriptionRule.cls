/**
 * DES-001: Missing Description
 *
 * Detects flows that are missing a description and elements with
 * names that appear to be auto-generated (Flow Builder defaults).
 *
 * Flow descriptions are critical for maintainability — they tell
 * future admins/developers WHAT the flow does and WHY it exists.
 * Auto-generated element names (like "myDecision", "Loop",
 * "Get_Records") make flows hard to understand at a glance.
 *
 * REMEDIATION:
 * - Add a clear description to the flow explaining its purpose
 * - Rename elements with meaningful, descriptive names
 * - Follow naming conventions: Decisions = "Check_*",
 *   Assignments = "Set_*", Loops = "Loop_*"
 */
public class MissingDescriptionRule implements FlowRule {

    // Common auto-generated names from Flow Builder
    private static final Set<String> AUTO_GENERATED_PATTERNS = new Set<String>{
        'myDecision', 'myRule', 'myLoop', 'myVariable',
        'myFormula', 'mySubflow', 'myWait'
    };

    // Generic single-word names that aren't descriptive
    private static final Set<String> GENERIC_NAMES = new Set<String>{
        'Loop', 'Decision', 'Assignment', 'Screen',
        'Get_Records', 'Create_Records', 'Update_Records',
        'Delete_Records', 'Subflow', 'Action'
    };

    public List<FlowFinding> evaluate(FlowMetadata.FlowDefinition flow, FlowAnalysisContext ctx) {
        List<FlowFinding> findings = new List<FlowFinding>();

        // Check 1: Flow-level description
        if (String.isBlank(flow.description)) {
            findings.add(
                new FlowFinding('DES-001', 'Missing Description', 'Design', 'Medium')
                    .withDescription(
                        'This flow has no description. Without a description, other admins ' +
                        'and developers cannot quickly understand the flow\'s purpose, ' +
                        'trigger conditions, or business context.'
                    )
                    .withRemediation(
                        'Add a description to the flow explaining: what it does, when it ' +
                        'triggers, and what business process it supports. Example: ' +
                        '"Updates Account rating when related Opportunities close. ' +
                        'Triggered after Opportunity record update."'
                    )
            );
        }

        // Check 2: Auto-generated or generic element names
        Integer autoNameCount = 0;
        for (FlowMetadata.FlowElement el : flow.getAllElements()) {
            if (el.name != null && isAutoGeneratedName(el.name)) {
                autoNameCount++;
            }
        }

        if (autoNameCount > 0) {
            findings.add(
                new FlowFinding('DES-001', 'Missing Description', 'Design', 'Low')
                    .withDescription(
                        autoNameCount + ' element(s) have auto-generated or generic names ' +
                        '(e.g., "myDecision", "Loop", "Get_Records"). These default names ' +
                        'make the flow difficult to understand and debug.'
                    )
                    .withRemediation(
                        'Rename elements with descriptive names that explain their purpose. ' +
                        'Follow naming conventions: Decisions = "Check_*", ' +
                        'Assignments = "Set_*", Loops = "Loop_Each_*", ' +
                        'Get Records = "Get_*".'
                    )
            );
        }

        return findings;
    }

    private Boolean isAutoGeneratedName(String name) {
        // Check exact matches against known auto-generated names
        if (AUTO_GENERATED_PATTERNS.contains(name) || GENERIC_NAMES.contains(name)) {
            return true;
        }
        // Check numbered variants (e.g., "myDecision2", "Loop_1")
        for (String pattern : AUTO_GENERATED_PATTERNS) {
            if (name.startsWith(pattern) && name.length() > pattern.length()) {
                String suffix = name.substring(pattern.length());
                if (suffix.isNumeric() || suffix.startsWith('_')) {
                    return true;
                }
            }
        }
        for (String generic : GENERIC_NAMES) {
            if (name.startsWith(generic) && name.length() > generic.length()) {
                String suffix = name.substring(generic.length());
                if (suffix.isNumeric() || (suffix.startsWith('_') && suffix.length() <= 3)) {
                    return true;
                }
            }
        }
        return false;
    }
}
